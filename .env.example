# DeerFlow-X 环境变量配置
# 复制此文件为 .env 并填写实际值

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/deerflowx
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ===== 认证 =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Supabase（可选，替代自建PostgreSQL）=====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===== AI 模型配置（硅基流动 SiliconFlow）====
# 硅基流动：100+ 模型，按量付费，新用户注册送 2000 万 Tokens
# 文档：https://docs.siliconflow.cn/
SILICONFLOW_API_KEY=sk-pvqbgxpyqojhhibldeycmhohogdipzxkoswtsgpcixrftutj
OPENAI_API_KEY=sk-pvqbgxpyqojhhibldeycmhohogdipzxkoswtsgpcixrftutj
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 模型分层策略（省钱 + 质量兼顾）
# 简单任务用：deepseek-ai/DeepSeek-V3.2  ¥2/M in / ¥3/M out
# 复杂Agent用：deepseek-ai/DeepSeek-V3    ¥2/M in / ¥8/M out
# 深度推理用：deepseek-ai/DeepSeek-R1    ¥2/M in / ¥8/M out
OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2

# ===== LangSmith（可选，LangGraph追踪）=====
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=deerflow-x

# ===== 前端 =====
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ===== 部署 =====
DEPLOY_MODE=development  # development | production
LOG_LEVEL=INFO
SENTRY_DSN=  # 可选，错误追踪

# ===== Stripe（商业化用）=====
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_TEAM_PRICE_ID=price_your-team-price-id
STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-price-id

# ===== 文件存储 =====
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=100

# ===== Rate Limiting =====
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
